@startuml 08-component-overview

!theme plain
skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam packagePadding 20

title High-Level Architecture

top to bottom direction

' === CLIENTS ===
rectangle "Clients" {
    [Developer\n(SDK)] as Dev
    [End User\n(Player + Wallet)] as User
}

' === PLATFORM ===
rectangle "Platform Backend\n(Self-hostable)" as Platform {
    [API &\nServices] as API
    database "Cache" as Cache
}

' === SEAL ===
rectangle "Seal\n(Decentralized Secrets)" as SealBox {
    [Key Servers] as Seal
    note bottom of Seal
      - Access control
      - Key derivation
      - Client-side decrypt
    end note
}

' === BLOCKCHAIN ===
rectangle "Sui Blockchain" as Sui {
    [Smart Contract] as Contract
    note bottom of Contract
      - Accounts & Balances
      - Video metadata
      - Whitelists
    end note
}

' === STORAGE ===
rectangle "Walrus" as Walrus {
    [Decentralized\nStorage] as Storage
    note bottom of Storage
      - HLS segments
      - Encrypted blobs
    end note
}

' === CONNECTIONS ===
Dev --> API : upload\nmanage
User --> API : watch

API --> Cache
Cache --> Storage : read

API --> Contract : state
API --> Storage : write

User --> Seal : decrypt key\n(private videos)
Seal --> Contract : verify access

@enduml
